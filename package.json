{
  "activationEvents": [
    "onLanguage:azure-pipelines",
    "onLanguage:yaml",
    "onLanguage:markdown",
    "onLanguage:plaintext"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ado-pipeline-navigator.replacementStringsCommand",
        "title": "ADO Pipeline Navigator: Replacement Strings"
      },
      {
        "command": "ado-pipeline-navigator.featureTogglesCommand",
        "title": "ADO Pipeline Navigator: Feature Toggles"
      }
    ],
    "configuration": {
      "properties": {
        "ado-pipeline-navigator.featureToggles": {
          "default": {},
          "description": "Controls the feature toggles for the ADO Pipeline Navigator extension.",
          "properties": {
            "InternetFetch": {
              "default": true,
              "description": "Enable/disable internet fetch feature.",
              "type": "boolean"
            },
            "ReplaceStrings": {
              "default": true,
              "description": "Enable/disable string replacements feature.",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "ado-pipeline-navigator.filePathKeys": {
          "default": [
            "systemTestTemplate"
          ],
          "description": "Custom keywords for opening local files. Any keyword listed here will behave like 'template' or 'file' - click to open the referenced file, show file path and content on hover. Add your own keywords (e.g., 'systemTestTemplate', 'deploymentTemplate', 'myCustomFile').",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ado-pipeline-navigator.keywordsToDisplayOnHover": {
          "default": null,
          "description": "Array of keywords to display on hover in the ADO Pipeline Navigator extension.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ado-pipeline-navigator.quickReplaceStringsCount": {
          "default": 5,
          "description": "Number of quick replace strings to display in the ADO Pipeline Navigator extension.",
          "type": "number"
        },
        "ado-pipeline-navigator.replacementStrings": {
          "default": [],
          "description": "Array of replacement strings",
          "items": {
            "properties": {
              "find": {
                "type": "string"
              },
              "replace": {
                "type": "string"
              }
            },
            "required": [
              "find",
              "replace"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "resources": [
        {
          "path": "navigate.png",
          "type": "image"
        }
      ],
      "title": "ADO Pipeline Navigator"
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "description": "Navigate Azure Pipeline templates with Ctrl+click",
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "terser-webpack-plugin": "^5.3.16",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  },
  "displayName": "ADO Pipeline Navigator",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionDependencies": [],
  "icon": "icon.png",
  "license": "MIT",
  "main": "./extension-bundle.js",
  "name": "ado-pipeline-navigator",
  "publisher": "RenyPaul",
  "repository": {
    "type": "git",
    "url": "https://github.com/HPInc/ado-pipeline-navigator.git"
  },
  "scripts": {
    "build:dev": "webpack --mode none",
    "build:prod": "webpack --mode production",
    "compile": "webpack --mode production",
    "test": "node tests/taskUrl.test.js"
  },
  "version": "1.3.1"
}
